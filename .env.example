# ── ai-obs environment configuration ────────────────────────────────────────
# Copy to .env and edit before running docker compose up.
# Values shown are safe defaults for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=aiobs

# ── MinIO (S3-compatible log archive) ───────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Collector ────────────────────────────────────────────────────────────────
# Set this in production — the SDK must send X-API-Key: <value> with every request
# AI_OBS_API_KEY=change-me-in-production-32-chars-minimum
COLLECTOR_PORT=8080
COLLECTOR_WORKERS=2
LOG_LEVEL=info

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# ── Docker image (for CI/CD push) ────────────────────────────────────────────
# DOCKER_IMAGE=jahnavik186/telemetryai-collector
# VERSION=0.2.0

# ── SDK settings (set these in your application, not here) ───────────────────
# These are shown here for reference — set them in your app's environment.
#
# AI_OBS_ENDPOINT=http://localhost:8080      # collector URL
# AI_OBS_API_KEY=                            # must match AI_OBS_API_KEY above
# AI_OBS_ENV=production                      # production | staging | development
# AI_OBS_BATCH_SIZE=50                       # events per HTTP flush
# AI_OBS_FLUSH_INTERVAL=5                    # seconds between flushes
# AI_OBS_SAMPLE_RATE=1.0                     # 1.0 = capture everything
# AI_OBS_DISABLE=false                       # true = silence SDK (useful in tests)
# AI_OBS_CAPTURE_PROMPTS=false               # store prompt text (privacy opt-in)
# AI_OBS_CAPTURE_COMPLETIONS=false           # store completion text (privacy opt-in)
